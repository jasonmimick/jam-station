# --- required ---
# The AI DJ's brain. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- change these before first run ---
ICECAST_SOURCE_PASSWORD=changeme-source
ICECAST_ADMIN_PASSWORD=changeme-admin
ICECAST_RELAY_PASSWORD=changeme-relay

# --- optional ---
# Model used for the DJ (any Anthropic model id)
ANTHROPIC_MODEL=claude-sonnet-4-5
# Prefetch upcoming Archive tracks to the shared cache volume (smoother playback,
# kinder to archive.org). true/false
PREFETCH=true
# Top up a channel's queue when fewer than this many tracks remain
MIN_QUEUE=4
TZ=America/New_York
